<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- =========================
         STEP 1: Clear table
         ========================= -->
    <changeSet id="01-truncate" author="Tejas" dbms="oracle">
        <sql>TRUNCATE TABLE CUSTOMER</sql>

        <!-- Rollback restores original data -->
        <rollback>
            <loadData
                file="scripts/new_file.csv"
                tableName="CUSTOMER"
                separator=","
                encoding="UTF-8">

                <column name="ID" header="ID"/>
                <column name="NAME" header="NAME"/>
                <column name="EMAIL" header="EMAIL"/>
                <column name="PHONE" header="PHONE"/>
            </loadData>
        </rollback>
    </changeSet>

    <!-- =========================
         STEP 2: Insert updated data
         ========================= -->
    <changeSet id="02-load-updated" author="Tejas" dbms="oracle">

        <loadData
                file="scripts/new_file.csv"
                tableName="CUSTOMER"
                separator=","
                encoding="UTF-8">

            <column name="ID" header="ID"/>
            <column name="NAME" header="NAME"/>
            <column name="EMAIL" header="EMAIL"/>
            <column name="PHONE" header="PHONE"/>

        </loadData>

        <!-- If rollback triggered -->
        <rollback>
            <sql>TRUNCATE TABLE CUSTOMER</sql>

            <loadData
                file="scripts/new_file.csv"
                tableName="CUSTOMER"
                separator=","
                encoding="UTF-8">

                <column name="ID" header="ID"/>
                <column name="NAME" header="NAME"/>
                <column name="EMAIL" header="EMAIL"/>
                <column name="PHONE" header="PHONE"/>
            </loadData>
        </rollback>

    </changeSet>

</databaseChangeLog>
