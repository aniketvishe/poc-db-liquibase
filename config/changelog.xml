<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
	<!--
	=========================================================
	STEP 0: Create backup table if not exists
	==========================================================
	-->
	<changeSet id="00-create-backup-table-v2" author="Aniket" dbms="oracle">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="MASTER_TABLE_BACKUP" schemaName="SYSTEM" />
			</not>
		</preConditions>
		<sql>
			CREATE TABLE SYSTEM.MASTER_TABLE_BACKUP AS
			SELECT * FROM SYSTEM.MASTER_TABLE WHERE 1=2;
		</sql>
	</changeSet>
	<!--
	=========================================================
	STEP 1: Backup existing data
	==========================================================
	-->
	<changeSet id="01-backup-data" author="Aniket" dbms="oracle" runAlways="true">
		<preConditions onFail="MARK_RAN">
			<tableExists tableName="MASTER_TABLE_BACKUP" schemaName="SYSTEM" />
		</preConditions>
		<sql>
			TRUNCATE TABLE SYSTEM.MASTER_TABLE_BACKUP;
			INSERT INTO SYSTEM.MASTER_TABLE_BACKUP
			SELECT * FROM SYSTEM.MASTER_TABLE;
		</sql>
	</changeSet>
	<!--
	=========================================================
	STEP 2: Clean main table
	==========================================================
	-->
	<changeSet id="02-clean-main-table" author="Aniket" dbms="oracle" runAlways="true">
		<sql>
			DELETE FROM SYSTEM.MASTER_TABLE;
		</sql>
	</changeSet>
	<!--
	=========================================================
	STEP 3: Load CSV data
	==========================================================
	-->
	<changeSet id="03-load-new-csv" author="Aniket" dbms="oracle" runAlways="true">
		<loadData file="scripts/new_file.csv" tableName="MASTER_TABLE" schemaName="SYSTEM" separator="," relativeToChangelogFile="true">
			<column name="ID" type="NUMERIC" />
			<column name="NAME" type="STRING" />
		</loadData>
		<!-- Rollback -->
		<rollback>
			DELETE FROM SYSTEM.MASTER_TABLE;
			INSERT INTO SYSTEM.MASTER_TABLE
			SELECT * FROM SYSTEM.MASTER_TABLE_BACKUP;
		</rollback>
	</changeSet>
</databaseChangeLog>
