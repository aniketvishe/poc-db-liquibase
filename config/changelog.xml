<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- =========================================================
         TABLE: MASTER_TABLE
         BACKUP TABLE: MASTER_TABLE_BACKUP
         ========================================================= -->


    <!-- =========================
         STEP 0: Create backup table (if not exists)
         ========================= -->
    <changeSet id="00-create-backup-table" author="Tejas" dbms="oracle">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="MASTER_TABLE_BACKUP"/>
            </not>
        </preConditions>

        <sql>
            CREATE TABLE MASTER_TABLE_BACKUP AS
            SELECT * FROM MASTER_TABLE WHERE 1=2;
        </sql>
    </changeSet>


    <!-- =========================
         STEP 1: Backup existing data
         ========================= -->
    <changeSet id="01-backup-data" author="Tejas" dbms="oracle" runAlways="true">
        <sql>
            DELETE FROM MASTER_TABLE_BACKUP;
            INSERT INTO MASTER_TABLE_BACKUP
            SELECT * FROM MASTER_TABLE;
            COMMIT;
        </sql>
    </changeSet>


    <!-- =========================
         STEP 2: Truncate main table
         ========================= -->
    <changeSet id="02-truncate-main-table" author="Tejas" dbms="oracle" runAlways="true">
        <sql>
            TRUNCATE TABLE MASTER_TABLE;
        </sql>
    </changeSet>


    <!-- =========================
         STEP 3: Load NEW CSV data
         ========================= -->
    <changeSet id="03-load-new-csv" author="Tejas" dbms="oracle" runAlways="true">

        <loadData
                file="scripts/new_file.csv"
                tableName="MASTER_TABLE"
                separator=","
                relativeToChangelogFile="true"
                usePreparedStatements="true"
                batchSize="1000"/>

        <!-- Rollback: restore old data -->
        <rollback>
            DELETE FROM MASTER_TABLE;
            INSERT INTO MASTER_TABLE
            SELECT * FROM MASTER_TABLE_BACKUP;
            COMMIT;
        </rollback>
    </changeSet>

</databaseChangeLog>
