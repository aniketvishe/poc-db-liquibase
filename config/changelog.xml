<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- =========================================================
         STEP 0: Ensure backup table always exists
         ========================================================= -->
    <changeSet id="00-create-backup-table" author="Tejas" dbms="oracle" runAlways="true">

        <sql splitStatements="false">
            BEGIN
                EXECUTE IMMEDIATE '
                    CREATE TABLE MASTER_TABLE_BACKUP AS
                    SELECT * FROM MASTER_TABLE WHERE 1=2
                ';
            EXCEPTION
                WHEN OTHERS THEN
                    IF SQLCODE != -955 THEN
                        RAISE;
                    END IF;
            END;
        </sql>

    </changeSet>


    <!-- =========================================================
         STEP 1: Backup existing data
         ========================================================= -->
    <changeSet id="01-backup-data" author="Tejas" dbms="oracle" runAlways="true">

        <sql>
            DELETE FROM MASTER_TABLE_BACKUP;
            INSERT INTO MASTER_TABLE_BACKUP
            SELECT * FROM MASTER_TABLE;
        </sql>

    </changeSet>


    <!-- =========================================================
         STEP 2: Clean main table (safe for Oracle)
         ========================================================= -->
    <changeSet id="02-clean-main-table" author="Tejas" dbms="oracle" runAlways="true">

        <sql>
            DELETE FROM MASTER_TABLE;
        </sql>

    </changeSet>


    <!-- =========================================================
         STEP 3: Load CSV data
         ========================================================= -->
    <changeSet id="03-load-new-csv" author="Tejas" dbms="oracle" runAlways="true">

        <loadData
                file="scripts/new_file.csv"
                tableName="MASTER_TABLE"
                separator=","
                relativeToChangelogFile="true"
                usePreparedStatements="true"
                batchSize="1000"/>

        <!-- Rollback -->
        <rollback>
            DELETE FROM MASTER_TABLE;
            INSERT INTO MASTER_TABLE
            SELECT * FROM MASTER_TABLE_BACKUP;
        </rollback>

    </changeSet>

</databaseChangeLog>
