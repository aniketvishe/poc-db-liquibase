<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
	<!--
	=========================================================
	STEP 0: Create backup table if not exists
	=========================================================
	-->
	<changeSet id="00-create-backup-table" author="Aniket" dbms="oracle">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="MASTER_TABLE_BACKUP" />
			</not>
		</preConditions>
		<sql>
			CREATE TABLE MASTER_TABLE_BACKUP AS
			SELECT * FROM MASTER_TABLE WHERE 1=2;
		</sql>
	</changeSet>
	<!--
	=========================================================
	STEP 1: Backup existing data
	=========================================================
	-->
	<changeSet id="01-backup-data" author="Aniket" dbms="oracle" runAlways="true">
		<preConditions onFail="HALT">
			<tableExists tableName="MASTER_TABLE_BACKUP" />
		</preConditions>
		<sql>
			TRUNCATE TABLE MASTER_TABLE_BACKUP;
			INSERT INTO MASTER_TABLE_BACKUP
			SELECT * FROM MASTER_TABLE;
		</sql>
	</changeSet>
	<!--
	=========================================================
	STEP 2: Clean main table
	=========================================================
	-->
	<changeSet id="02-clean-main-table" author="Aniket" dbms="oracle" runAlways="true">
		<sql>
			DELETE FROM MASTER_TABLE;
		</sql>
	</changeSet>
	<!--
	=========================================================
	STEP 3: Load CSV data
	=========================================================
	-->
	<changeSet id="03-load-new-csv" author="Aniket" dbms="oracle" runAlways="true">
		<loadData file="scripts/new_file.csv" tableName="MASTER_TABLE" separator="," relativeToChangelogFile="true">
			<column name="ID" type="NUMERIC" />
			<column name="NAME" type="STRING" />
		</loadData>
		<!-- Rollback -->
		<rollback>
			FROM MASTER_TABLE;
			INTO MASTER_TABLE
			* FROM MASTER_TABLE_BACKUP;
		</rollback>
	</changeSet>
</databaseChangeLog>
